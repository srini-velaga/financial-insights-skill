{
  "institution": "wells_fargo",
  "display_name": "Wells Fargo",
  "account_type": "credit_card",
  "file_type": "csv",
  "delimiter": ",",
  "has_header": true,
  "skip_rows": 0,
  "encoding": "utf-8",
  "header_fingerprint": ["Master Category", "Subcategory", "Date", "Location", "Payee", "Description", "Payment Method", "Amount"],
  "columns": {
    "transaction_date": { "name": "Date", "format": "%m/%d/%Y" },
    "description": { "name": "Description" },
    "amount": { "name": "Amount" },
    "category": { "name": "Master Category" },
    "subcategory": { "name": "Subcategory" },
    "location": { "name": "Location" },
    "card_name": { "name": "Payment Method" }
  },
  "amount_handling": {
    "style": "single",
    "sign_convention": "positive_is_charge",
    "strip_chars": "$,"
  },
  "category_mappings": {
    "Food/Drink|Groceries": ["Food & Dining", "Groceries"],
    "Food/Drink|Restaurants": ["Food & Dining", "Restaurants"],
    "Food/Drink|Fast Food": ["Food & Dining", "Fast Food"],
    "Food/Drink|Coffee Shops": ["Food & Dining", "Coffee"],
    "Food/Drink|Bars/Alcohol": ["Food & Dining", "Bars"],
    "Auto/Transportation|Gasoline": ["Transportation", "Gas"],
    "Auto/Transportation|Parking/Tolls": ["Transportation", "Parking"],
    "Auto/Transportation|Public Transportation": ["Transportation", "Public Transit"],
    "Auto/Transportation|Maintenance/Repair": ["Transportation", "Maintenance"],
    "Travel|Airfare": ["Travel", "Airfare"],
    "Travel|Rental Car": ["Travel", "Rental Car"],
    "Travel|Hotel": ["Travel", "Hotels"],
    "Shopping|Other Shopping": ["Shopping", "General"],
    "Shopping|Clothing/Accessories": ["Shopping", "Clothing"],
    "Shopping|Electronics/Software": ["Shopping", "Electronics"],
    "Shopping|Sporting Goods": ["Shopping", "Sporting Goods"],
    "Bills/Utilities|Rent": ["Bills & Utilities", "Rent"],
    "Bills/Utilities|Electricity": ["Bills & Utilities", "Electric"],
    "Bills/Utilities|Cable/Satellite TV": ["Bills & Utilities", "Cable"],
    "Bills/Utilities|Internet": ["Bills & Utilities", "Internet"],
    "Bills/Utilities|Cell Phone": ["Bills & Utilities", "Phone"],
    "Entertainment|Movies/Music": ["Entertainment", "Media"],
    "Entertainment|Other Entertainment": ["Entertainment", "General"],
    "Health|Doctor/Hospital": ["Health", "Medical"],
    "Health|Pharmacy": ["Health", "Pharmacy"],
    "Health|Gym/Fitness": ["Health", "Fitness"],
    "Home|Home Improvement": ["Home", "Improvement"],
    "Home|Furnishing": ["Home", "Furnishing"],
    "Insurance/Financial|Insurance": ["Insurance & Financial", "Insurance"],
    "Insurance/Financial|Banking Fees": ["Insurance & Financial", "Banking Fees"],
    "Business/Office|Accounting/Payroll Services": ["Business Services", "Accounting"],
    "Business/Office|Postage/Shipping": ["Business Services", "Shipping"],
    "Miscellaneous|Charity": ["Gifts & Donations", "Charity"],
    "Credit Card/Loan Payments|Credit Card Payment": ["Payments & Credits", "Payment"],
    "Uncategorized Payments|Other": ["Payments & Credits", "General"]
  },
  "notes": "Export year-end summary from wellsfargo.com > Statements & Documents > Year End Summary. Download as CSV."
}
