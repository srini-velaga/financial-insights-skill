{
  "institution": "chase",
  "display_name": "Chase",
  "account_type": "checking",
  "file_type": "csv",
  "delimiter": ",",
  "has_header": true,
  "skip_rows": 0,
  "encoding": "utf-8",
  "header_fingerprint": ["Details", "Posting Date", "Description", "Amount", "Type", "Balance", "Check or Slip #"],
  "columns": {
    "transaction_date": { "name": "Posting Date", "format": "%m/%d/%Y" },
    "description": { "name": "Description" },
    "amount": { "name": "Amount" },
    "transaction_type": { "name": "Details" }
  },
  "amount_handling": {
    "style": "single",
    "sign_convention": "negative_is_charge",
    "strip_chars": "$,"
  },
  "category_mappings": {},
  "notes": "Export from chase.com > See full activity > Download. Checking account transactions use different headers than credit card."
}
